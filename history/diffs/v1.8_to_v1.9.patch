+  pausePlayback,
+  resumePlayback,
+  stopPlayback,
+  isPlaying,
+  playNextOrRandom,
+  playPrevious,
+  addTrackToPlaylist,
+  removeTrackFromPlaylist,
+  updateMusicPanel,
+};
