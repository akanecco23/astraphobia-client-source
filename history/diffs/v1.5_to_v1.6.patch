+      targetX - Math.cos(targetAngle - 0.5) * 10,
+      targetY - Math.sin(targetAngle - 0.5) * 10,
+    );
+    ctx.lineTo(
+      targetX - Math.cos(targetAngle + 0.5) * 10,
+      targetY - Math.sin(targetAngle + 0.5) * 10,
+    );
+    ctx.closePath();
