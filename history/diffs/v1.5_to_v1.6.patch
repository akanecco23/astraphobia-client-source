+      coreSharedState.dataList = [];
+      coreSharedState.targetReference = null;
+      return;
+    }
+    const currentTime = Date.now();
+    let hasMoved = false;
+    if (currentTime - coreSharedState.lastTimeB > 600) {
+      coreSharedState.lastTimeB = currentTime;
