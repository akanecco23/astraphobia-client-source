{
  "_meta": {
    "version": "1.9",
    "lastUpdated": null,
    "description": "Module definitions and bootstrap patterns for the splitter. Modules are discovered automatically by the LLM."
  },
  "modules": {
    "core": { "path": "core" },
    "utils": { "path": "utils" },
    "storage": { "path": "storage" },
    "features_aimbot": {
      "path": "features/aimbot",
      "description": "Auto-lock, auto-dodge, entity tracking"
    },
    "features_autofarm": {
      "path": "features/autofarm",
      "description": "Auto-farming, food collection, evolution"
    },
    "features_chat": {
      "path": "features/chat",
      "description": "Chat automation, spam, auto-chat"
    },
    "features_adblock": {
      "path": "features/adblock",
      "description": "Ad blocking and hiding"
    },
    "features_esp": {
      "path": "features/esp",
      "description": "ESP overlays, player boxes, health bars, minimap radar"
    },
    "features_entitytrail": {
      "path": "features/entitytrail",
      "description": "Entity trail tracking, trail rendering, trail history"
    },
    "features_movement": {
      "path": "features/movement",
      "description": "Auto-movement, waypoints, pointer control"
    },
    "features_xray": {
      "path": "features/xray",
      "description": "X-ray vision / AstraVision"
    },
    "features_antidetection": {
      "path": "features/antidetection",
      "description": "Anti-detection and anti-ban"
    },
    "ui": {
      "path": "ui/panels",
      "description": "Main UI panels, toggle, settings menu"
    },
    "ui_interaction": {
      "path": "ui/interaction",
      "description": "Text input simulation, notifications, autofill"
    },
    "ui_audio": {
      "path": "ui/audio",
      "description": "YouTube player, music playlist, audio controls"
    },
    "ui_radar": {
      "path": "ui/radar",
      "description": "Radar/minimap canvas, lock button UI"
    },
    "ui_theme": {
      "path": "ui/theme",
      "description": "Theme application, background images, CSS injection"
    }
  },
  "bootstrap": {
    "exactNames": ["initializeApplication"],
    "prefixes": ["launch"],
    "suffixes": ["OnLoad", "Bootstrap"],
    "minCallees": 5
  },
  "scoreThreshold": 5
}
